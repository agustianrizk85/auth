# env & secrets
.env

# Ed25519 signing keys — NEVER commit the private key. Root-anchored so it does
# NOT also ignore the internal/keys/ SOURCE package (which broke cmd/server build).
/keys/
*.pem

# build output (root binaries only — NOT the cmd/server source dir)
auth-server
/server
/devserver
*.exe
*.exe~

# AI assistant secret key (set via UI) + runtime data/logs
# NOTE: keys are named data/openrouter.key OR data/ollama.key — never commit any.
/data/
local.err
local.out
*.log
