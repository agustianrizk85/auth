# Salin ke `.env` lalu sesuaikan (di-load oleh shell/PM2, bukan oleh Go langsung).

# Port HTTP API auth.
AUTH_PORT=8090

# CORS: daftar origin frontend dipisah koma (pakai domain nyata di produksi).
# Untuk lokal boleh "*". Jika memakai daftar, hanya origin yang cocok yang diizinkan.
AUTH_ALLOW_ORIGIN=*

# DSN PostgreSQL (WAJIB — penyimpanan hanya Postgres).
AUTH_DATABASE_URL=postgres://user:pass@localhost:5432/greenpark?sslmode=disable

# Identitas penerbit token (klaim "iss"). Harus sama dengan yang dicek departemen.
AUTH_ISSUER=greenpark-auth

# Masa berlaku access token (pendek) dan refresh token (panjang, bisa di-revoke).
AUTH_ACCESS_TTL=15m
AUTH_REFRESH_TTL=720h

# Lokasi kunci penandatangan Ed25519. Dibuat otomatis saat pertama jalan bila belum ada.
# JANGAN commit private key. Public key boleh dibagikan ke departemen.
AUTH_PRIVATE_KEY_PATH=keys/ed25519_private.pem
AUTH_PUBLIC_KEY_PATH=keys/ed25519_public.pem

# Bootstrap superadmin pertama (hanya dipakai saat tabel user masih kosong).
# Set password sekali untuk membuat akun, lalu kosongkan/ganti setelahnya.
AUTH_BOOTSTRAP_USERNAME=superadmin
AUTH_BOOTSTRAP_NAME=Super Admin
# AUTH_BOOTSTRAP_PASSWORD=ganti-dengan-password-kuat
